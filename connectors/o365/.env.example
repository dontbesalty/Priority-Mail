# O365 / Outlook Connector
# Copy to .env and fill in values.
# ──────────────────────────────────────────────────────────────────────────────
# STEP 1 — Register an Azure App
#   1. Go to https://portal.azure.com → Azure Active Directory → App registrations
#   2. New registration → Name: "Priority Mail", Supported account types:
#      "Personal Microsoft accounts only" (for @outlook.com / @hotmail.com)
#      or "Accounts in any org directory and personal accounts" (for both)
#   3. Platform: "Mobile and desktop applications"
#      Redirect URI: http://localhost:3001/callback
#   4. API Permissions → Add → Microsoft Graph → Delegated:
#        Mail.Read    offline_access    User.Read
#   5. Copy Application (client) ID → OUTLOOK_CLIENT_ID below
#   6. No client secret needed for public clients
# ──────────────────────────────────────────────────────────────────────────────

OUTLOOK_CLIENT_ID=your-azure-app-client-id-here

# Tenant ID:
#   "consumers"  — personal @outlook.com / @hotmail.com accounts
#   "common"     — any Microsoft account (personal + work/school)
#   "<tenant-id>" — specific Entra ID / Azure AD tenant (work accounts only)
OUTLOOK_TENANT_ID=consumers

# The Outlook / O365 account email address.
# Shown as the source tag in the Priority Mail dashboard.
OUTLOOK_ACCOUNT_EMAIL=you@outlook.com

# After running `npm run auth`, paste the refresh token printed here:
OUTLOOK_REFRESH_TOKEN=

# ── Port for the one-time local OAuth callback server ─────────────────────────
# Must match the Redirect URI registered in Azure.
# Use 3001 (not 3000) to avoid clashing with the Gmail auth server or the
# Next.js frontend when both are running simultaneously.
AUTH_PORT=3001

# ── How many unread emails to fetch per run ───────────────────────────────────
# Increase if you receive many emails in 24 hours
FETCH_LIMIT=200

# ── Backend endpoint ──────────────────────────────────────────────────────────
# When running via docker compose:  http://backend:4000
# When running locally:             http://localhost:4000
BACKEND_URL=http://backend:4000

# ── OpenRouter — AI classification ────────────────────────────────────────────
# Shared key with the Gmail connector (both drain from the same rate limit pool)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# ── Local AI — for confidential emails ────────────────────────────────────────
# Same setup as Gmail connector. See connectors/gmail/.env.example for details.
# For docker compose with Ollama on the host:
#   LOCAL_AI_URL=http://host.docker.internal:11434/v1
LOCAL_AI_URL=
LOCAL_AI_MODEL=llama3.2
