# Gmail connector — copy to .env and fill in values
# ─────────────────────────────────────────────
# OAuth credentials (Desktop app type in Google Cloud Console)
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here

# The Gmail account to authorize
GMAIL_ACCOUNT_EMAIL=you@gmail.com

# Obtained by running: npm run auth
GMAIL_REFRESH_TOKEN=

# ─────────────────────────────────────────────
# OpenRouter — AI classification
# Get a key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-your-key-here
# Free tier model (change to openai/gpt-4o-mini for higher quality)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ─────────────────────────────────────────────
# Local AI — for confidential emails
#
# Emails containing confidentiality notices (e.g. "This email is confidential",
# "privileged and confidential", "attorney-client privilege") will NOT be sent
# to OpenRouter. Instead they are routed to a local OpenAI-compatible endpoint.
#
# How to set up Ollama locally:
#   brew install ollama && ollama pull llama3.2
#   ollama serve   ← starts on http://localhost:11434
#
# Then set:
#   LOCAL_AI_URL=http://localhost:11434/v1
#   LOCAL_AI_MODEL=llama3.2
#
# When running via docker compose with Ollama on the host:
#   LOCAL_AI_URL=http://host.docker.internal:11434/v1
#
# If LOCAL_AI_URL is not set, confidential emails are classified by rules
# only (High priority / Client Request) — they are never sent to any cloud AI.
LOCAL_AI_URL=
LOCAL_AI_MODEL=llama3.2

# ─────────────────────────────────────────────
# Optional: post triaged emails to the backend API (Docker stack mode)
# When running via docker compose, set this to http://backend:4000
BACKEND_URL=

# ─────────────────────────────────────────────
# Tuning
FETCH_LIMIT=20
# Port for the one-time auth callback server (default: 3000)
AUTH_PORT=3000
